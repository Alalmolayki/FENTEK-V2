# ════════════════════════════════════════════════════════════
#  FenTECH 2026 — Apache (.htaccess) yapılandırması
#  Bu dosyayı sitenin KÖK dizinine (index.html ile aynı yere) koyun.
#  cPanel / Plesk gibi paneller bu dosyayı genelde "public_html"
#  veya "httpdocs" klasörü içinde arar.
# ════════════════════════════════════════════════════════════

# ── 1) HTTP → HTTPS yönlendirmesi ─────────────────────────────
# Hosting sağlayıcınızdan ücretsiz SSL sertifikası (Let's Encrypt
# vb.) kurduktan SONRA bu bloğun etkin olduğundan emin olun.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ── 2) www ↔ www'siz yönlendirme (TERCİHİNİZE GÖRE birini açın) ──
# Aşağıdaki iki seçenekten yalnızca BİRİNİN başındaki "#" işaretlerini
# kaldırın (ikisini birden açmayın — yönlendirme döngüsü oluşur).
#
# (a) www'siz adresi tercih ediyorsanız (ör. dogmfentekaihl.com):
# <IfModule mod_rewrite.c>
#   RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
#   RewriteRule ^(.*)$ https://%1/$1 [L,R=301]
# </IfModule>
#
# (b) www'li adresi tercih ediyorsanız (ör. www.dogmfentekaihl.com):
# <IfModule mod_rewrite.c>
#   RewriteCond %{HTTP_HOST} !^www\. [NC]
#   RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [L,R=301]
# </IfModule>

# ── 3) Doğru karakter kümesi (Türkçe karakterlerin bozulmaması için) ──
AddDefaultCharset UTF-8
<IfModule mod_mime.c>
  AddType text/html .html .htm
  AddCharset UTF-8 .html .htm .css .js .svg .json
</IfModule>

# ── 4) Sıkıştırma (gzip) — sayfa daha hızlı yüklenir ──────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── 5) Tarayıcı önbellekleme — statik dosyalar tekrar tekrar
#       indirilmesin, site daha hızlı açılsın ───────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                  "access plus 1 month"
  ExpiresByType application/javascript    "access plus 1 month"
  ExpiresByType text/javascript           "access plus 1 month"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType application/pdf           "access plus 1 month"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType text/html                 "access plus 0 seconds"
</IfModule>

# ── 6) Temel güvenlik başlıkları ──────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── 7) Klasör içeriği listelenmesin (ör. /pdfs/ adresine girilince
#       dosya listesi görünmesin) ────────────────────────────────
Options -Indexes

# ── 8) .htaccess, .git, .claude gibi dosya/klasörlere dışarıdan
#       erişim engellensin ───────────────────────────────────────
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
